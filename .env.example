# ─── Database (Azure PostgreSQL Flexible Server) ────────────────────
DATABASE_URL=postgresql+asyncpg://jarvisadmin:CHANGE_ME@jarvis-db.postgres.database.azure.com:5432/jarvis?ssl=require

# ─── Server ─────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── Azure Key Vault ────────────────────────────────────────────────
AZURE_KEYVAULT_URL=https://jarvis-kv.vault.azure.net/

# ─── Keycloak OIDC (mandatory) ──────────────────────────────────────
KEYCLOAK_URL=https://keycloak.company.com
KEYCLOAK_REALM=jarvis
KEYCLOAK_CLIENT_ID=jarvis-automation
KEYCLOAK_CLIENT_SECRET=

# ─── HTTP/1.1 Proxy for BeyondTrust Cloud (optional) ────────────────
HTTP11_PROXY_URL=
